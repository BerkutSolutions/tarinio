# Testpage environment (non-default profile)

# Public host for test site certificate + routing
TEST_WAF_DOMAIN=localhost

# Host HTTPS port mapped to runtime container:443
TEST_WAF_HTTPS_PORT=8080

# IDs in control-plane state
TEST_WAF_CERTIFICATE_ID=testpage-localhost-tls
TEST_WAF_SITE_ID=testpage-localhost-site

# Docker-internal upstream target
TEST_WAF_UPSTREAM_HOST=test-login-app
TEST_WAF_UPSTREAM_PORT=80

# Optional DB overrides
POSTGRES_USER=waf
POSTGRES_PASSWORD=waf
POSTGRES_DB=waf
POSTGRES_DSN=postgres://waf:waf@postgres:5432/waf?sslmode=disable

# Optional runtime anti-DDoS defaults for this profile
WAF_L4_GUARD_ENABLED=false
WAF_L4_GUARD_CHAIN_MODE=input
WAF_L4_GUARD_CONN_LIMIT=200
WAF_L4_GUARD_RATE_PER_SECOND=100
WAF_L4_GUARD_RATE_BURST=200
WAF_L4_GUARD_DESTINATION_IP=

# Direct UI port for full test profile

# Testpage environment (dual-stack profile: management + protected app)

# Management stack
MGMT_WAF_DOMAIN=localhost
MGMT_WAF_HTTPS_PORT=8080
MGMT_WAF_CERTIFICATE_ID=testpage-mgmt-localhost-tls
MGMT_WAF_SITE_ID=testpage-mgmt-localhost-site
MGMT_WAF_UPSTREAM_PORT=80
MGMT_WAF_DEFAULT_LIMIT_REQ_RATE=20r/s
MGMT_WAF_DEFAULT_BAD_BEHAVIOR_BAN_TIME_SECONDS=10

# Protected app stack
TEST_WAF_DOMAIN=localhost
TEST_APP_WAF_HTTPS_PORT=8081
TEST_WAF_CERTIFICATE_ID=testpage-app-localhost-tls
TEST_WAF_SITE_ID=testpage-app-localhost-site
TEST_WAF_UPSTREAM_PORT=80
TEST_WAF_DEFAULT_LIMIT_REQ_RATE=5r/s
TEST_WAF_DEFAULT_BAD_BEHAVIOR_BAN_TIME_SECONDS=10

# Databases
MGMT_POSTGRES_USER=waf
MGMT_POSTGRES_PASSWORD=waf
MGMT_POSTGRES_DB=waf
MGMT_POSTGRES_DSN=postgres://waf:waf@postgres-mgmt:5432/waf?sslmode=disable

TEST_POSTGRES_USER=waf
TEST_POSTGRES_PASSWORD=waf
TEST_POSTGRES_DB=waf
TEST_POSTGRES_DSN=postgres://waf:waf@postgres-app:5432/waf?sslmode=disable

# Runtime adaptive L4 guard
WAF_L4_GUARD_REAPPLY_INTERVAL_SECONDS=5

# Adaptive DDoS model
DDOS_MODEL_POLL_INTERVAL_SECONDS=2
DDOS_MODEL_DECAY_LAMBDA=0.08
DDOS_MODEL_THROTTLE_THRESHOLD=2.5
DDOS_MODEL_DROP_THRESHOLD=6.0
DDOS_MODEL_HOLD_SECONDS=60
DDOS_MODEL_THROTTLE_RATE_PER_SECOND=3
DDOS_MODEL_THROTTLE_BURST=6
DDOS_MODEL_THROTTLE_TARGET=REJECT
DDOS_MODEL_WEIGHT_429=1.0
DDOS_MODEL_WEIGHT_403=1.8
DDOS_MODEL_WEIGHT_444=2.2
DDOS_MODEL_EMERGENCY_RPS=180
DDOS_MODEL_EMERGENCY_UNIQUE_IPS=40
DDOS_MODEL_EMERGENCY_PER_IP_RPS=60
DDOS_MODEL_WEIGHT_EMERGENCY_BOTNET=6.0
DDOS_MODEL_WEIGHT_EMERGENCY_SINGLE=4.0

# Request archive
REQUEST_ARCHIVE_MAX_FILE_SIZE_MB=256
REQUEST_ARCHIVE_MAX_FILES=7
REQUEST_ARCHIVE_RETENTION_DAYS=2

WAF_STACK_NAME=waf

POSTGRES_USER=waf
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=waf
POSTGRES_DSN=postgres://waf:change-me-strong-password@postgres:5432/waf?sslmode=disable
WAF_RUNTIME_API_TOKEN=change-me-runtime-api-token
OPENSEARCH_ENDPOINT=http://opensearch:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=change-me-opensearch-password

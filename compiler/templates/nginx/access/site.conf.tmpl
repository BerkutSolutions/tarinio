{{- range .TrustedProxyCIDRs }}
set_real_ip_from {{ . }};
{{- end }}
{{- if .TrustedProxyCIDRs }}
real_ip_header X-Forwarded-For;
real_ip_recursive on;
{{- end }}
{{- range .AllowCIDRs }}
allow {{ . }};
{{- end }}
{{- range .DenyCIDRs }}
deny {{ . }};
{{- end }}
{{- if eq .DefaultAction "deny" }}
deny all;
{{- end }}

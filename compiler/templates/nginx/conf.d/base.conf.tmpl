proxy_http_version 1.1;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto $scheme;
proxy_buffering on;
proxy_buffer_size 64k;
proxy_buffers 16 64k;
proxy_busy_buffers_size 512k;
proxy_temp_file_write_size 512k;
proxy_max_temp_file_size 0;
geoip_country /usr/share/GeoIP/GeoIP.dat;

map $http_cf_ipcountry $waf_country_from_cf {
    default "";
    ~(?i)^[A-Z][A-Z]$ $http_cf_ipcountry;
}

map $http_x_country_code $waf_country_from_x_country_code {
    default "";
    ~(?i)^[A-Z][A-Z]$ $http_x_country_code;
}

map $http_x_geo_country $waf_country_from_x_geo_country {
    default "";
    ~(?i)^[A-Z][A-Z]$ $http_x_geo_country;
}

map $http_x_country $waf_country_from_x_country {
    default "";
    ~(?i)^[A-Z][A-Z]$ $http_x_country;
}

map $waf_country_from_cf $waf_country_header_step_1 {
    "" $waf_country_from_x_country_code;
    default $waf_country_from_cf;
}

map $waf_country_header_step_1 $waf_country_header_step_2 {
    "" $waf_country_from_x_geo_country;
    default $waf_country_header_step_1;
}

map $waf_country_header_step_2 $waf_country_header {
    "" $waf_country_from_x_country;
    default $waf_country_header_step_2;
}

map $waf_country_header $waf_country_code {
    "" $geoip_country_code;
    default $waf_country_header;
}

map $http_x_city $waf_city_from_x_city {
    default "";
    ~(?i)^[A-Za-z0-9._-]+$ $http_x_city;
}

map $http_x_geo_city $waf_city_from_x_geo_city {
    default "";
    ~(?i)^[A-Za-z0-9._-]+$ $http_x_geo_city;
}

map $http_cf_ipcity $waf_city_from_cf {
    default "";
    ~(?i)^[A-Za-z0-9._-]+$ $http_cf_ipcity;
}

map $waf_city_from_cf $waf_city_header_step_1 {
    "" $waf_city_from_x_city;
    default $waf_city_from_cf;
}

map $waf_city_header_step_1 $waf_city_header {
    "" $waf_city_from_x_geo_city;
    default $waf_city_header_step_1;
}

map $waf_city_header $waf_city_name {
    "" $geoip_city;
    default $waf_city_header;
}

map $host $waf_site_id {
{{- range .HostMapEntries }}
    {{ .Host }} "{{ .SiteID }}";
{{- end }}
    default "_global";
}

map $host $waf_site_id_log {
{{- range .HostMapEntries }}
    {{ .Host }} "{{ .SiteID }}";
{{- end }}
    default "_global";
}

map $waf_site_id_log $waf_management_telemetry {
{{- if .ManagementSiteID }}
    "{{ .ManagementSiteID }}" 1;
{{- end }}
    default 0;
}

map "$waf_site_id:$uri" $waf_unknown_host {
    ~^_global:(?!/\.well-known/acme-challenge/) 1;
    default 0;
}

map $host $waf_direct_ip_request {
    ~^[0-9][0-9]?[0-9]?\.[0-9][0-9]?[0-9]?\.[0-9][0-9]?[0-9]?\.[0-9][0-9]?[0-9]?$ 1;
    ~^\[[0-9A-Fa-f:]+\]$ 1;
    ~^[0-9A-Fa-f:]+$ 1;
    default 0;
}

map "$waf_site_id_log:$waf_direct_ip_request" $waf_security_reason {
{{- if .BlockDirectIPAccess }}
    "_global:1" "direct_ip_blocked";
{{- else }}
    "_global:1" "direct_ip_access";
{{- end }}
    "_global:0" "unknown_host";
    default "";
}

log_format waf_security_json escape=json '{"timestamp":"$time_iso8601","request_id":"$request_id","client_ip":"$remote_addr","country":"$waf_country_code","city":"$waf_city_name","host":"$host","method":"$request_method","uri":"$request_uri","status":$status,"bytes_sent":$body_bytes_sent,"referer":"$http_referer","user_agent":"$http_user_agent","site":"$waf_site_id_log","management":$waf_management_telemetry,"security_reason":"$waf_security_reason","upstream_addr":"$upstream_addr","request_time":$request_time}';
access_log /var/log/nginx/access.log waf_security_json;

limit_req_zone $binary_remote_addr zone=waf_management_login_req:10m rate=5r/s;

server {
    listen 80 default_server;
    server_name _;
    add_header Server-Timing "rid;desc=$request_id,ip;desc=$remote_addr,ts;desc=$msec" always;
    proxy_intercept_errors on;
{{- range .ErrorStatusCodes }}
    error_page {{ . }} /__waf_errors/_global/{{ . }}.html?rid=$request_id&ip=$remote_addr&ts=$msec;
{{- end }}

{{- range .ErrorStatusCodes }}
    location = /__waf_errors/_global/{{ . }}.html {
        internal;
        allow all;
        default_type text/html;
        alias /etc/waf/errors/_global/{{ . }}.html;
    }
{{- end }}

{{- if .BlockDirectIPAccess }}
    if ($waf_direct_ip_request = 1) {
        return 444;
    }
{{- end }}
    if ($waf_unknown_host = 1) {
        rewrite ^ /__waf_errors/_global/421.html last;
    }

    location ^~ /.well-known/acme-challenge/ {
        modsecurity off;
        default_type text/plain;
        log_not_found off;
        alias /var/lib/waf/control-plane/acme-challenges/;
    }

    location ^~ /api/ {
        proxy_intercept_errors off;
        proxy_pass {{ .ManagementAPIProxyTarget }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location = / {
        return 302 /login;
    }

    location = /login {
        limit_req zone=waf_management_login_req burst=20 nodelay;
{{- if .ManagementSiteID }}
        include /etc/waf/nginx/ratelimits/{{ .ManagementSiteID }}.conf;
        include /etc/waf/nginx/easy/{{ .ManagementSiteID }}.conf;
{{- else }}
        limit_req_status 429;
{{- end }}
        proxy_pass {{ .UIProxyTarget }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location = /login/2fa {
        limit_req zone=waf_management_login_req burst=20 nodelay;
{{- if .ManagementSiteID }}
        include /etc/waf/nginx/ratelimits/{{ .ManagementSiteID }}.conf;
        include /etc/waf/nginx/easy/{{ .ManagementSiteID }}.conf;
{{- else }}
        limit_req_status 429;
{{- end }}
        proxy_pass {{ .UIProxyTarget }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location ^~ /onboarding/ {
        proxy_pass {{ .UIProxyTarget }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location ^~ /static/ {
        proxy_pass {{ .UIProxyTarget }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location = /preview/geo-block {
        allow all;
        default_type text/html;
        alias /etc/waf/errors/_global/geo_block.html;
    }

    location = /preview/400 { allow all; default_type text/html; alias /etc/waf/errors/_global/400.html; }
    location = /preview/401 { allow all; default_type text/html; alias /etc/waf/errors/_global/401.html; }
    location = /preview/403 { allow all; default_type text/html; alias /etc/waf/errors/_global/403.html; }
    location = /preview/404 { allow all; default_type text/html; alias /etc/waf/errors/_global/404.html; }
    location = /preview/405 { allow all; default_type text/html; alias /etc/waf/errors/_global/405.html; }
    location = /preview/408 { allow all; default_type text/html; alias /etc/waf/errors/_global/408.html; }
    location = /preview/421 { allow all; default_type text/html; alias /etc/waf/errors/_global/421.html; }
    location = /preview/429 { allow all; default_type text/html; alias /etc/waf/errors/_global/429.html; }
    location = /preview/402 { allow all; default_type text/html; alias /etc/waf/errors/_global/402.html; }
    location = /preview/406 { allow all; default_type text/html; alias /etc/waf/errors/_global/406.html; }
    location = /preview/407 { allow all; default_type text/html; alias /etc/waf/errors/_global/407.html; }
    location = /preview/409 { allow all; default_type text/html; alias /etc/waf/errors/_global/409.html; }
    location = /preview/410 { allow all; default_type text/html; alias /etc/waf/errors/_global/410.html; }
    location = /preview/411 { allow all; default_type text/html; alias /etc/waf/errors/_global/411.html; }
    location = /preview/412 { allow all; default_type text/html; alias /etc/waf/errors/_global/412.html; }
    location = /preview/413 { allow all; default_type text/html; alias /etc/waf/errors/_global/413.html; }
    location = /preview/414 { allow all; default_type text/html; alias /etc/waf/errors/_global/414.html; }
    location = /preview/415 { allow all; default_type text/html; alias /etc/waf/errors/_global/415.html; }
    location = /preview/416 { allow all; default_type text/html; alias /etc/waf/errors/_global/416.html; }
    location = /preview/417 { allow all; default_type text/html; alias /etc/waf/errors/_global/417.html; }
    location = /preview/418 { allow all; default_type text/html; alias /etc/waf/errors/_global/418.html; }
    location = /preview/422 { allow all; default_type text/html; alias /etc/waf/errors/_global/422.html; }
    location = /preview/423 { allow all; default_type text/html; alias /etc/waf/errors/_global/423.html; }
    location = /preview/424 { allow all; default_type text/html; alias /etc/waf/errors/_global/424.html; }
    location = /preview/425 { allow all; default_type text/html; alias /etc/waf/errors/_global/425.html; }
    location = /preview/426 { allow all; default_type text/html; alias /etc/waf/errors/_global/426.html; }
    location = /preview/428 { allow all; default_type text/html; alias /etc/waf/errors/_global/428.html; }
    location = /preview/431 { allow all; default_type text/html; alias /etc/waf/errors/_global/431.html; }
    location = /preview/444 { allow all; default_type text/html; alias /etc/waf/errors/_global/444.html; }
    location = /preview/500 { allow all; default_type text/html; alias /etc/waf/errors/_global/500.html; }
    location = /preview/501 { allow all; default_type text/html; alias /etc/waf/errors/_global/501.html; }
    location = /preview/502 { allow all; default_type text/html; alias /etc/waf/errors/_global/502.html; }
    location = /preview/503 { allow all; default_type text/html; alias /etc/waf/errors/_global/503.html; }
    location = /preview/504 { allow all; default_type text/html; alias /etc/waf/errors/_global/504.html; }
    location = /preview/505 { allow all; default_type text/html; alias /etc/waf/errors/_global/505.html; }
    location = /preview/507 { allow all; default_type text/html; alias /etc/waf/errors/_global/507.html; }
    location = /preview/508 { allow all; default_type text/html; alias /etc/waf/errors/_global/508.html; }
    location = /preview/510 { allow all; default_type text/html; alias /etc/waf/errors/_global/510.html; }
    location = /preview/511 { allow all; default_type text/html; alias /etc/waf/errors/_global/511.html; }

    location / {
        return 308 https://$host$request_uri;
    }
}


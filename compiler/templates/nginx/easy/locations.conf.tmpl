{{- if .AntibotEnabled }}
{{- if .AntibotTwoLayerEnabled }}
location = {{ .AntibotStage1URI }} {
    proxy_intercept_errors off;
    modsecurity off;
    add_header Set-Cookie "{{ .AntibotStage1CookieName }}={{ .AntibotStage1CookieValue }}; Max-Age=120; Path=/; SameSite=Lax; Secure; HttpOnly" always;
    return 204;
}
location = {{ .AntibotStage1VerifyURI }} {
    proxy_intercept_errors off;
    modsecurity off;
    set $waf_antibot_return_path /;
    set $waf_antibot_return_query "";
    if ($arg_return_uri != "") {
        set $waf_antibot_return_path $arg_return_uri;
    }
    if ($arg_return_uri ~* "%") {
        set $waf_antibot_return_path /;
        set $waf_antibot_return_query "";
    }
    if ($arg_return_args != "") {
        set $waf_antibot_return_query ?$arg_return_args;
    }
    add_header Cache-Control "no-store" always;
    add_header Set-Cookie "{{ .AntibotStage1CookieName }}={{ .AntibotStage1CookieValue }}; Max-Age=120; Path=/; SameSite=Lax; Secure; HttpOnly" always;
    return 302 $scheme://$host$waf_antibot_return_path$waf_antibot_return_query;
}
{{- end }}
location = {{ .AntibotURI }} {
    proxy_intercept_errors off;
    modsecurity off;
{{- if .AntibotUsesInterstitial }}
    default_type text/html;
    alias /etc/waf/errors/{{ .SiteID }}/antibot.html;
{{- else }}
    add_header Set-Cookie "{{ .AntibotCookieName }}={{ .AntibotCookieValue }}; Max-Age=600; Path=/; SameSite=Lax; Secure; HttpOnly" always;
    return 204;
{{- end }}
}
location = {{ .AntibotVerifyURI }} {
    proxy_intercept_errors off;
    modsecurity off;
    add_header Cache-Control "no-store" always;
    add_header Set-Cookie "{{ .AntibotCookieName }}={{ .AntibotCookieValue }}; Max-Age=600; Path=/; SameSite=Lax; Secure; HttpOnly" always;
{{- if .AntibotUsesInterstitial }}
    return 204;
{{- else }}
    set $waf_antibot_return_path /;
    set $waf_antibot_return_query "";
    if ($arg_return_uri != "") {
        set $waf_antibot_return_path $arg_return_uri;
    }
    if ($arg_return_uri ~* "%") {
        set $waf_antibot_return_path /;
        set $waf_antibot_return_query "";
    }
    if ($arg_return_args != "") {
        set $waf_antibot_return_query ?$arg_return_args;
    }
    if ($waf_antibot_return_path !~ "^/") {
        set $waf_antibot_return_path /;
        set $waf_antibot_return_query "";
    }
    return 302 $scheme://$host$waf_antibot_return_path$waf_antibot_return_query;
{{- end }}
}
{{- end }}
{{- if .AuthEnabled }}
location = {{ .AuthGateLoginURI }} {
    proxy_intercept_errors off;
    modsecurity off;
    default_type text/html;
    alias /etc/waf/errors/{{ .SiteID }}/auth.html;
}
{{- if .AuthBasicEnabled }}
location = {{ .AuthGateVerifyBasicURI }} {
    proxy_intercept_errors off;
    modsecurity off;
    auth_basic "{{ .AuthBasicRealm }}";
    auth_basic_user_file {{ .AuthBasicUserFile }};
    add_header Cache-Control "no-store" always;
{{- if ge .AuthGateCookieTTL 0 }}
    add_header Set-Cookie "{{ .AuthGateCookieKey }}={{ .AuthGateCookieVal }}; Max-Age={{ .AuthGateCookieTTL }}; Path=/; SameSite=Lax; Secure; HttpOnly" always;
{{- else }}
    add_header Set-Cookie "{{ .AuthGateCookieKey }}={{ .AuthGateCookieVal }}; Path=/; SameSite=Lax; Secure; HttpOnly" always;
{{- end }}
    # auth_basic is evaluated in the access phase. A rewrite-phase return would
    # bypass it, so finish the request only after access controls have run.
    try_files /__waf_auth_verified__ =204;
}
{{- end }}
{{- if .AuthTokenEnabled }}
location = {{ .AuthGateVerifyTokenURI }} {
    proxy_intercept_errors off;
    modsecurity off;
    set $waf_auth_token_verified 0;
    set $waf_auth_service_guard "$http_x_waf_service_name|$http_x_waf_service_token";
    set $waf_auth_bearer_guard "$http_x_waf_service_name|$http_authorization";
{{- range .AuthTokenRules }}
    if ($waf_auth_service_guard = "{{ .ServiceGuard }}") { set $waf_auth_token_verified 1; }
    if ($waf_auth_bearer_guard = "{{ .BearerGuard }}") { set $waf_auth_token_verified 1; }
{{- end }}
    if ($waf_auth_token_verified = 0) { return 401; }
    add_header Cache-Control "no-store" always;
{{- if ge .AuthGateCookieTTL 0 }}
    add_header Set-Cookie "{{ .AuthGateCookieKey }}={{ .AuthGateCookieVal }}; Max-Age={{ .AuthGateCookieTTL }}; Path=/; SameSite=Lax; Secure; HttpOnly" always;
{{- else }}
    add_header Set-Cookie "{{ .AuthGateCookieKey }}={{ .AuthGateCookieVal }}; Path=/; SameSite=Lax; Secure; HttpOnly" always;
{{- end }}
    return 204;
}
{{- end }}
{{- end }}
{{- range .Rules }}
location {{ .LocationModifier }} {{ .LocationPath }} {
{{- if .DisableProxyInterceptErrors }}
    proxy_intercept_errors off;
{{- end }}
    include /etc/waf/nginx/easy/{{ $.SiteID }}.conf;
    limit_req zone={{ .ZoneName }} burst={{ .Burst }} nodelay;
    limit_req_status {{ .StatusCode }};
{{- if .PassHostHeader }}
    proxy_set_header Host $http_host;
{{- end }}
{{- if .IsAdminAPIPath }}
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Real-IP $remote_addr;
{{- end }}
    proxy_pass {{ .ProxyPassTarget }};
}
{{- end }}

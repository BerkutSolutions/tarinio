# Easy-mode compiler directives for this site.

client_max_body_size {{ .MaxClientSize }};
client_body_buffer_size 512k;
{{- if .HttpStrictParsing }}
ignore_invalid_headers on;
underscores_in_headers off;
proxy_set_header Transfer-Encoding "";
{{- end }}
set $waf_rate_limited_max_age {{ .RateLimitBanSeconds }};
set $waf_rate_limited_active 0;
set $waf_rate_limited_escalated 0;
set $waf_easy_exception_guard 0;
set $waf_easy_admin_guard 0;
set $waf_antibot_effective_challenge "no";
set $waf_antibot_effective_redirect "";
if ($uri ~* "{{ .AdminBypassPathPattern }}") {
    set $waf_easy_admin_guard 1;
}
if ($cookie_waf_session != "") {
    set $waf_easy_admin_guard 1;
}
if ($cookie_waf_session_boot != "") {
    set $waf_easy_admin_guard 1;
}
if (${{ .ExceptionVar }} = 1) {
    set $waf_easy_exception_guard 1;
}
if ($waf_easy_admin_guard = 1) {
    set $waf_easy_exception_guard 1;
}

if ($waf_rate_limited_max_age ~ "^[1-9][0-9]*$") {
    set $waf_rate_limited_active 1;
}
if ($cookie_{{ .RateLimitCookieVar }} != "1") {
    set $waf_rate_limited_active 0;
}
if ($cookie_{{ .RateLimitEscalationCookieVar }} = "1") {
    set $waf_rate_limited_escalated 1;
}
if ($waf_easy_exception_guard = 1) {
    set $waf_rate_limited_active 0;
    set $waf_rate_limited_escalated 0;
}
if ($waf_rate_limited_escalated = 1) {
    return 403;
}
if ($waf_rate_limited_active = 1) {
    return 429;
}

if ($request_method !~ {{ .AllowedMethodsPattern }}) {
    return 405;
}

{{- if .ReferrerPolicy }}
add_header Referrer-Policy "{{ .ReferrerPolicy }}" always;
{{- end }}
{{- if .ContentSecurityPolicy }}
add_header Content-Security-Policy "{{ .ContentSecurityPolicy }}" always;
{{- end }}
{{- if .PermissionsPolicy }}
add_header Permissions-Policy "{{ .PermissionsPolicy }}" always;
{{- end }}
{{- if .HSTSHeader }}
add_header Strict-Transport-Security "{{ .HSTSHeader }}" always;
{{- end }}
{{- if .UseCORS }}
add_header Access-Control-Allow-Origin "{{ .CORSAllowedOrigins }}" always;
add_header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS" always;
add_header Access-Control-Allow-Headers "*" always;
{{- end }}

{{- if and .PassHostHeader .ReverseProxyCustomHost }}
proxy_set_header Host {{ .ReverseProxyCustomHost }};
{{- end }}
{{- if .SendXForwardedFor }}
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
{{- else }}
proxy_set_header X-Forwarded-For "";
{{- end }}
{{- if .SendXForwardedProto }}
proxy_set_header X-Forwarded-Proto $scheme;
{{- else }}
proxy_set_header X-Forwarded-Proto "";
{{- end }}
{{- if .SendXRealIP }}
proxy_set_header X-Real-IP $remote_addr;
{{- else }}
proxy_set_header X-Real-IP "";
{{- end }}
{{- if .ReverseProxySSLSNI }}
proxy_ssl_server_name on;
{{- if .ReverseProxySSLSNIName }}
proxy_ssl_name {{ .ReverseProxySSLSNIName }};
{{- end }}
{{- else }}
proxy_ssl_server_name off;
{{- end }}
{{- if .UpstreamMTLSSnippet }}
{{ .UpstreamMTLSSnippet }}
{{- end }}
{{- if .ReverseProxyWebsocket }}
proxy_http_version 1.1;
proxy_set_header Upgrade $http_upgrade;
proxy_set_header Connection "upgrade";
{{- end }}
{{- if .ReverseProxyKeepalive }}
proxy_set_header Connection "";
{{- end }}

{{- if and .AuthEnabled .AuthRunsBeforeAntibot }}
set $waf_auth_gate_skip 0;
if ($uri = "/login") { set $waf_auth_gate_skip 1; }
if ($uri = "/login/2fa") { set $waf_auth_gate_skip 1; }
if ($uri = "{{ .AuthGateLoginURI }}") { set $waf_auth_gate_skip 1; }
{{- if .AuthBasicEnabled }}
if ($uri = "{{ .AuthGateVerifyBasicURI }}") { set $waf_auth_gate_skip 1; }
{{- end }}
{{- if .AuthTokenEnabled }}
if ($uri = "{{ .AuthGateVerifyTokenURI }}") { set $waf_auth_gate_skip 1; }
{{- end }}
{{- if .AntibotEnabled }}
if ($uri = "{{ .AntibotURI }}") { set $waf_auth_gate_skip 1; }
if ($uri = "{{ .AntibotVerifyURI }}") { set $waf_auth_gate_skip 1; }
{{- if .AntibotTwoLayerEnabled }}
if ($uri = "{{ .AntibotStage1URI }}") { set $waf_auth_gate_skip 1; }
if ($uri = "{{ .AntibotStage1VerifyURI }}") { set $waf_auth_gate_skip 1; }
{{- end }}
{{- end }}
set $waf_auth_exclusion_match "$request_method:$uri";
{{- range .AuthExclusionRules }}
if ($waf_auth_exclusion_match ~* "{{ .MatchPattern }}") { set $waf_auth_gate_skip 1; }
{{- end }}
set $waf_auth_cookie_verified 0;
if ($cookie_{{ .AuthGateCookieKey }} = "{{ .AuthGateCookieVal }}") { set $waf_auth_cookie_verified 1; }
set $waf_auth_header_verified 0;
{{- if .AuthTokenEnabled }}
set $waf_auth_service_guard "$http_x_waf_service_name|$http_x_waf_service_token";
set $waf_auth_bearer_guard "$http_x_waf_service_name|$http_authorization";
{{- range .AuthTokenRules }}
if ($waf_auth_service_guard = "{{ .ServiceGuard }}") { set $waf_auth_header_verified 1; }
if ($waf_auth_bearer_guard = "{{ .BearerGuard }}") { set $waf_auth_header_verified 1; }
{{- end }}
{{- end }}
set $waf_auth_gate_verified 0;
if ($waf_auth_cookie_verified = 1) { set $waf_auth_gate_verified 1; }
if ($waf_auth_header_verified = 1) { set $waf_auth_gate_verified 1; }
if ($waf_auth_gate_skip = 0) {
    if ($waf_auth_gate_verified = 0) { return 302 {{ .AuthGateLoginURI }}?return_uri=$uri&return_args=$args; }
}
{{- end }}

{{- if .UseModSecurityEasyFile }}
modsecurity_rules_file /etc/waf/modsecurity/easy/{{ .SiteID }}.conf;
{{- end }}

{{- range .BlacklistIP }}
deny {{ . }};
{{- end }}

{{- range .BlacklistUserAgent }}
set $waf_blacklist_ua_guard "$waf_easy_exception_guard:$http_user_agent";
if ($waf_blacklist_ua_guard ~* "^0:.*{{ . }}") { return 403; }
{{- end }}

{{- range .BlacklistURI }}
set $waf_blacklist_uri_guard "$waf_easy_exception_guard:$request_uri";
if ($waf_blacklist_uri_guard ~* "^0:.*{{ . }}") { return 403; }
{{- end }}

{{- if .WhitelistCountryGuardPattern }}
set $waf_country_guard "$waf_easy_exception_guard:$waf_country_code";
if ($waf_country_guard !~ "{{ .WhitelistCountryGuardPattern }}") { return 403; }
{{- end }}

{{- if .BlacklistCountryGuardPattern }}
set $waf_country_guard "$waf_easy_exception_guard:$waf_country_code";
if ($waf_country_guard ~ "{{ .BlacklistCountryGuardPattern }}") { return 403; }
{{- end }}

{{- if .GeoTimeWindowSnippet }}
{{ .GeoTimeWindowSnippet }}
{{- end }}

{{- if .WSInspectionSnippet }}
{{ .WSInspectionSnippet }}
{{- end }}

{{- if .MTLSSnippet }}
{{ .MTLSSnippet }}
{{- end }}

{{- if and .AntibotEnabled .AntibotScannerAutoBan }}
set $waf_antibot_scanner_guard "$waf_easy_exception_guard:$request_uri:$http_user_agent";
if ($waf_antibot_scanner_guard ~* "^0:.*(?:{{ .AntibotScannerPattern }})") { return 403; }
{{- end }}

{{- if .AntibotEnabled }}
# Easy antibot guard: requests are challenged unless a site-scoped challenge cookie is present.
set $waf_antibot_exception_guard 0;
if ($cookie_waf_session != "") { set $waf_antibot_exception_guard 1; }
if ($cookie_waf_session_boot != "") { set $waf_antibot_exception_guard 1; }
if (${{ .ExceptionVar }} = 1) { set $waf_antibot_exception_guard 1; }
set $waf_antibot_exclusion_match "$request_method:$uri";
{{- range .AntibotExclusionRules }}
if ($waf_antibot_exclusion_match ~* "{{ .MatchPattern }}") { set $waf_antibot_exception_guard 1; }
{{- end }}
set $waf_antibot_effective_challenge "{{ .AntibotChallenge }}";
set $waf_antibot_effective_redirect "{{ .AntibotRedirectURI }}";
{{- range .AntibotRuleOverrides }}
if ($uri ~* "{{ .GuardPattern }}") {
    set $waf_antibot_effective_challenge "{{ .Challenge }}";
    set $waf_antibot_effective_redirect "{{ .RedirectURI }}";
}
{{- end }}
set $waf_antibot_verified 0;
if ($cookie_{{ .AntibotCookieName }} = "{{ .AntibotCookieValue }}") { set $waf_antibot_verified 1; }
set $waf_antibot_stage1_verified 0;
if ($cookie_{{ .AntibotStage1CookieName }} = "{{ .AntibotStage1CookieValue }}") { set $waf_antibot_stage1_verified 1; }
set $waf_antibot_safe_method 0;
if ($request_method = GET) { set $waf_antibot_safe_method 1; }
if ($request_method = HEAD) { set $waf_antibot_safe_method 1; }
set $waf_antibot_guard "$waf_antibot_exception_guard:$waf_antibot_verified:$waf_antibot_safe_method";
{{- if .AntibotTwoLayerEnabled }}
if ($waf_antibot_guard = "0:0:1") {
    if ($waf_antibot_stage1_verified = 0) { return 302 {{ .AntibotStage1RedirectURI }}?return_uri=$uri&return_args=$args; }
    return 302 $waf_antibot_effective_redirect?return_uri=$uri&return_args=$args;
}
{{- else }}
if ($waf_antibot_guard = "0:0:1") { return 302 $waf_antibot_effective_redirect?return_uri=$uri&return_args=$args; }
{{- end }}
if ($waf_antibot_guard ~ "^0:0:") { return 403; }
add_header X-WAF-Antibot-Mode "$waf_antibot_effective_challenge" always;
{{- if .AntibotRecaptchaHint }}
add_header X-WAF-Antibot-Provider "recaptcha" always;
{{- end }}
{{- if .AntibotHcaptchaHint }}
add_header X-WAF-Antibot-Provider "hcaptcha" always;
{{- end }}
{{- if .AntibotTurnstileHint }}
add_header X-WAF-Antibot-Provider "turnstile" always;
{{- end }}
{{- end }}

{{- if and .AuthEnabled (not .AuthRunsBeforeAntibot) }}
set $waf_auth_gate_skip 0;
if ($uri = "/login") { set $waf_auth_gate_skip 1; }
if ($uri = "/login/2fa") { set $waf_auth_gate_skip 1; }
if ($uri = "{{ .AuthGateLoginURI }}") { set $waf_auth_gate_skip 1; }
{{- if .AuthBasicEnabled }}
if ($uri = "{{ .AuthGateVerifyBasicURI }}") { set $waf_auth_gate_skip 1; }
{{- end }}
{{- if .AuthTokenEnabled }}
if ($uri = "{{ .AuthGateVerifyTokenURI }}") { set $waf_auth_gate_skip 1; }
{{- end }}
{{- if .AntibotEnabled }}
if ($uri = "{{ .AntibotURI }}") { set $waf_auth_gate_skip 1; }
if ($uri = "{{ .AntibotVerifyURI }}") { set $waf_auth_gate_skip 1; }
{{- if .AntibotTwoLayerEnabled }}
if ($uri = "{{ .AntibotStage1URI }}") { set $waf_auth_gate_skip 1; }
if ($uri = "{{ .AntibotStage1VerifyURI }}") { set $waf_auth_gate_skip 1; }
{{- end }}
{{- end }}
set $waf_auth_exclusion_match "$request_method:$uri";
{{- range .AuthExclusionRules }}
if ($waf_auth_exclusion_match ~* "{{ .MatchPattern }}") { set $waf_auth_gate_skip 1; }
{{- end }}
set $waf_auth_cookie_verified 0;
if ($cookie_{{ .AuthGateCookieKey }} = "{{ .AuthGateCookieVal }}") { set $waf_auth_cookie_verified 1; }
set $waf_auth_header_verified 0;
{{- if .AuthTokenEnabled }}
set $waf_auth_service_guard "$http_x_waf_service_name|$http_x_waf_service_token";
set $waf_auth_bearer_guard "$http_x_waf_service_name|$http_authorization";
{{- range .AuthTokenRules }}
if ($waf_auth_service_guard = "{{ .ServiceGuard }}") { set $waf_auth_header_verified 1; }
if ($waf_auth_bearer_guard = "{{ .BearerGuard }}") { set $waf_auth_header_verified 1; }
{{- end }}
{{- end }}
set $waf_auth_gate_verified 0;
if ($waf_auth_cookie_verified = 1) { set $waf_auth_gate_verified 1; }
if ($waf_auth_header_verified = 1) { set $waf_auth_gate_verified 1; }
if ($waf_auth_gate_skip = 0) {
    if ($waf_auth_gate_verified = 0) { return 302 {{ .AuthGateLoginURI }}?return_uri=$uri&return_args=$args; }
}
{{- end }}

{{- if not .UseModSecurity }}
modsecurity off;
{{- end }}

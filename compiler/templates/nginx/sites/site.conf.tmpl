    location = /preview/415 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/415.html; }
    location = /preview/416 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/416.html; }
    location = /preview/417 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/417.html; }
    location = /preview/418 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/418.html; }
    location = /preview/422 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/422.html; }
    location = /preview/423 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/423.html; }
    location = /preview/424 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/424.html; }
    location = /preview/425 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/425.html; }
    location = /preview/426 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/426.html; }
    location = /preview/428 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/428.html; }
    location = /preview/431 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/431.html; }
    location = /preview/444 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/444.html; }
    location = /preview/500 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/500.html; }
    location = /preview/501 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/501.html; }

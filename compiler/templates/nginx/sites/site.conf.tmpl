    location = /preview/408 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/408.html; }
    location = /preview/421 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/421.html; }
    location = /preview/429 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/429.html; }

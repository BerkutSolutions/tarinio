    location = /preview/505 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/505.html; }
    location = /preview/507 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/507.html; }
    location = /preview/508 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/508.html; }
    location = /preview/510 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/510.html; }
    location = /preview/511 { allow all; modsecurity off; default_type text/html; alias /etc/waf/errors/_global/511.html; }
{{- end }}

{{- if .IsManagementSite }}
    location ^~ /api/ {
        # API clients must receive upstream status and JSON bodies unchanged.
        # The easy include below still enforces WAF rules for the endpoint.
        proxy_intercept_errors off;
	include /etc/waf/nginx/ratelimits/{{ .SiteID }}.conf;
	include /etc/waf/nginx/easy/{{ .SiteID }}.conf;
        proxy_pass {{ .ManagementAPIProxyTarget }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }
{{- else }}
    location ^~ /api/ {
        proxy_intercept_errors off;
{{- if and (not .UseEasyConfig) (not .IsManagementSite) }}
        modsecurity on;
        modsecurity_rules_file /etc/waf/modsecurity/sites/{{ .SiteID }}.conf;
{{- end }}
        include /etc/waf/nginx/ratelimits/{{ .SiteID }}.conf;
{{- if .PassHostHeader }}
        proxy_set_header Host $http_host;
{{- end }}
        include /etc/waf/nginx/easy/{{ .SiteID }}.conf;
        proxy_pass {{ .ProxyPassTarget }};
    }
{{- end }}

    location / {
{{- if and (not .UseEasyConfig) (not .IsManagementSite) }}
        modsecurity on;
        modsecurity_rules_file /etc/waf/modsecurity/sites/{{ .SiteID }}.conf;
{{- end }}
        include /etc/waf/nginx/ratelimits/{{ .SiteID }}.conf;
{{- if .PassHostHeader }}
        proxy_set_header Host $http_host;
{{- end }}
{{- if .HealthCheckEnabled }}
        proxy_next_upstream error timeout http_502 http_503;
        proxy_next_upstream_tries 2;
{{- end }}
        include /etc/waf/nginx/easy/{{ .SiteID }}.conf;
        proxy_pass {{ .ProxyPassTarget }};
    }
}

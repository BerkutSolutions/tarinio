upstream {{ .UpstreamName }} {
    server {{ .UpstreamAddress }};
{{- if .HealthCheckEnabled }}
    keepalive 32;
{{- end }}
}

server {
{{- if .ListenHTTP }}
    listen 80;
{{- end }}
{{- if .ListenHTTPS }}
    listen 443 ssl;
    include /etc/waf/tls/{{ .SiteID }}.conf;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;
    ssl_ecdh_curve X25519:secp384r1;
{{- end }}
{{- if .MTLSSnippet }}
{{ .MTLSSnippet }}
{{- end }}
    include /etc/waf/nginx/access/{{ .SiteID }}.conf;
    set $waf_antibot_effective_challenge "no";
    set $waf_host_allowed 0;
{{- range .ServerNames }}
    if ($host = "{{ . }}") { set $waf_host_allowed 1; }
{{- end }}
    if ($waf_host_allowed = 0) { return 421; }
    server_name {{ range $index, $name := .ServerNames }}{{ if $index }} {{ end }}{{ $name }}{{ end }};
    add_header X-WAF-Runtime-Revision "{{ .RuntimeRevisionID }}" always;
    add_header Server-Timing 'rid;desc="$request_id",ip;desc="$remote_addr",ts;desc="$msec"' always;
{{- if or (not .UseEasyConfig) (and .UseEasyConfig .UseCustomErrorPages) }}
    proxy_intercept_errors on;
{{- end }}
{{- if not .UseEasyConfig }}
{{- range .ErrorStatusCodes }}
    error_page {{ . }} /__waf_errors/{{ $.SiteID }}/{{ . }}.html?rid=$request_id&ip=$remote_addr&ts=$msec;
{{- end }}
    error_page 599 =403 /__waf_errors/_global/geo_block.html?rid=$request_id&ip=$remote_addr&ts=$msec&cc=$waf_country_code;
{{- end }}

    location = /__waf_errors/{{ .SiteID }}/400.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/400.html;
    }

    location = /__waf_errors/{{ .SiteID }}/401.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/401.html;
    }

    location = /__waf_errors/{{ .SiteID }}/403.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/403.html;
    }

    location = /__waf_errors/{{ .SiteID }}/404.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/404.html;
    }

    location = /__waf_errors/{{ .SiteID }}/405.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/405.html;
    }

    location = /__waf_errors/{{ .SiteID }}/408.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/408.html;
    }

    location = /__waf_errors/{{ .SiteID }}/421.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/421.html;
    }

    location = /__waf_errors/{{ .SiteID }}/429.html {
        internal;
        allow all;
        if ($cookie_{{ .RateLimitCookie }} = "1") {
            add_header Set-Cookie "{{ .RateLimitEscalationCookie }}=1; Max-Age=$waf_rate_limited_max_age; Path=/; SameSite=Lax; Secure" always;
        }
        add_header Set-Cookie "{{ .RateLimitCookie }}=1; Max-Age=$waf_rate_limited_max_age; Path=/; SameSite=Lax; Secure" always;
        alias /etc/waf/errors/{{ .SiteID }}/429.html;
    }

    location = /__waf_errors/_global/geo_block.html {
        internal;
        allow all;
        alias /etc/waf/errors/_global/geo_block.html;
    }

    # Canonical error artifacts are generated per site. This catch-all keeps
    # newly registered pages available without adding unsafe public paths.
    location ~ ^/__waf_errors/([a-zA-Z0-9_-]+)/([0-9]+\.html)$ {
        internal;
        allow all;
        alias /etc/waf/errors/$1/$2;
    }

    location = /__waf_errors/{{ .SiteID }}/500.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/500.html;
    }

    location = /__waf_errors/{{ .SiteID }}/502.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/502.html;
    }

    location = /__waf_errors/{{ .SiteID }}/503.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/503.html;
    }

    location = /__waf_errors/{{ .SiteID }}/504.html {
        internal;
        allow all;
        alias /etc/waf/errors/{{ .SiteID }}/504.html;
    }

    include /etc/waf/nginx/easy-locations/{{ .SiteID }}.conf;

    location ^~ /.well-known/acme-challenge/ {
        proxy_intercept_errors off;
        modsecurity off;
        default_type text/plain;
        alias /var/lib/waf/control-plane/acme-challenges/;
    }

{{- if .IsManagementSite }}
    location = /login {
        limit_req zone=waf_management_login_req burst=20 nodelay;
	include /etc/waf/nginx/ratelimits/{{ .SiteID }}.conf;
        add_header Cache-Control "no-store" always;
        # Management login must pass through the same challenge guard as the
        # rest of the site. The challenge and verification locations are
        # separate and therefore cannot form a redirect loop here.
        include /etc/waf/nginx/easy/{{ .SiteID }}.conf;
        proxy_pass {{ .UIProxyTarget }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location = /login/2fa {
        limit_req zone=waf_management_login_req burst=20 nodelay;
	include /etc/waf/nginx/ratelimits/{{ .SiteID }}.conf;
        add_header Cache-Control "no-store" always;
        include /etc/waf/nginx/easy/{{ .SiteID }}.conf;
        proxy_pass {{ .UIProxyTarget }};
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }
{{- end }}

    location ^~ /static/ {
        allow all;
        proxy_intercept_errors off;
{{- if .PassHostHeader }}
        proxy_set_header Host $http_host;
{{- end }}
        include /etc/waf/nginx/easy/{{ .SiteID }}.conf;
        proxy_pass {{ .ProxyPassTarget }};
    }

{{- if .IsManagementSite }}

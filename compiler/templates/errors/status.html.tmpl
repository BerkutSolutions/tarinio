      var lang = "en";
      try {
        var candidates = [];
        if (Array.isArray(navigator.languages)) candidates = candidates.concat(navigator.languages);
        if (navigator.language) candidates.push(navigator.language);
        for (var i = 0; i < candidates.length; i += 1) {
          var token = String(candidates[i] || "").toLowerCase().split(/[-_]/)[0];
          if (copy[token]) {
            lang = token;
            break;
          }
        }
      } catch (_error) {}
      var t = copy[lang] || copy.en;
      var p = phrases[lang] || {};
      document.documentElement.lang = lang;
      var requestLabel = document.getElementById("meta-request-label");
      var clientLabel = document.getElementById("meta-client-label");
      var timeLabel = document.getElementById("meta-time-label");
      var happenedTitle = document.getElementById("what-happened-title");
      var nextTitle = document.getElementById("what-next-title");
      var footer = document.getElementById("status-footer");
      if (requestLabel) requestLabel.textContent = t.requestID;
      if (clientLabel) clientLabel.textContent = t.clientIP;
      if (timeLabel) timeLabel.textContent = t.timestamp;
      if (happenedTitle) happenedTitle.textContent = t.whatHappened;
      if (nextTitle) nextTitle.textContent = t.whatNext;
      if (footer) footer.textContent = t.footer;
      // translate section titles (client/waf/upstream) from copy map
      var clientTitleNode = document.getElementById("client-title");
      var wafTitleNode = document.getElementById("waf-title");
      var upstreamTitleNode = document.getElementById("upstream-title");
      if (clientTitleNode) clientTitleNode.textContent = t.clientTitle;
      if (wafTitleNode) wafTitleNode.textContent = t.wafTitle;
      if (upstreamTitleNode) upstreamTitleNode.textContent = t.upstreamTitle;
      // translate server-rendered strings (Category, Title, Summary, state texts/labels, suggestions)
      function translateNode(id) {
        if (!p) return;
        var node = document.getElementById(id);
        if (!node) return;
        var src = String(node.textContent || "").trim();
        if (src && Object.prototype.hasOwnProperty.call(p, src)) {
          node.textContent = p[src];
        }
      }
      ["status-category", "status-main-title", "status-summary",
       "client-text", "client-label",
       "waf-text", "waf-label",
       "upstream-text", "upstream-label"].forEach(translateNode);
      if (p) {
        document.querySelectorAll(".list li").forEach(function (item) {
          var src = String(item.textContent || "").trim();
          if (src && Object.prototype.hasOwnProperty.call(p, src)) {
            item.textContent = p[src];
          }
        });
      }

      function readFromServerTiming(metricName) {
        try {
          var entries = performance.getEntriesByType("navigation");
          if (!entries || !entries.length) {
            return "";
          }
          var nav = entries[0];
          if (!nav.serverTiming || !nav.serverTiming.length) {
            return "";
          }
          for (var i = 0; i < nav.serverTiming.length; i += 1) {
            var metric = nav.serverTiming[i];
            if (metric && metric.name === metricName && metric.description) {
              return String(metric.description);
            }
          }
        } catch (_e) {
          return "";
        }
        return "";
      }

      var params = new URLSearchParams(window.location.search || "");
      var requestID = params.get("rid") || readFromServerTiming("rid") || "n/a";
      var clientIP = params.get("ip") || readFromServerTiming("ip") || "n/a";
      var rawMillis = params.get("ts") || readFromServerTiming("ts");

      var timestamp = "n/a";
      if (rawMillis) {
        var asNumber = Number(rawMillis);
        if (!Number.isNaN(asNumber) && Number.isFinite(asNumber)) {
          var date = new Date(asNumber * 1000);
          if (!Number.isNaN(date.getTime())) {
            try {
              timestamp = new Intl.DateTimeFormat(lang, {
                dateStyle: "medium",
                timeStyle: "medium"
              }).format(date);
            } catch (_fe) {
              timestamp = date.toLocaleString();
            }
          }
        }
      }

      var reqIDNode = document.getElementById("req-id");
      var clientIPNode = document.getElementById("client-ip");
      var timeNode = document.getElementById("req-time");
      if (reqIDNode) reqIDNode.textContent = requestID;
      if (clientIPNode) clientIPNode.textContent = clientIP;
      if (timeNode) timeNode.textContent = timestamp;
    })();

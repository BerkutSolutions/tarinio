<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Security Check</title>
<style>
:root{color-scheme:dark}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:#04060f;color:#e2e8f0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Inter,sans-serif}
body{display:flex;align-items:center;justify-content:center;min-height:100vh;overflow:hidden;padding:20px}
body::before{content:'';position:fixed;inset:0;background:
  radial-gradient(ellipse 120% 80% at -10% 120%,rgba(99,102,241,.18) 0%,transparent 50%),
  radial-gradient(ellipse 80% 60% at 110% -10%,rgba(139,92,246,.14) 0%,transparent 50%),
  radial-gradient(ellipse 60% 50% at 50% 50%,rgba(99,102,241,.06) 0%,transparent 70%);
  pointer-events:none}
body::after{content:'';position:fixed;inset:0;
  background:repeating-linear-gradient(135deg,transparent,transparent 40px,rgba(99,102,241,.018) 40px,rgba(99,102,241,.018) 41px);
  pointer-events:none}
.card{position:relative;width:100%;max-width:520px;padding:48px 44px;background:rgba(10,11,22,.88);border:1px solid rgba(99,102,241,.18);border-radius:20px;backdrop-filter:blur(20px);box-shadow:0 0 0 1px rgba(99,102,241,.07),0 32px 90px rgba(0,0,0,.65);overflow:hidden}
.card::after{content:'';position:absolute;left:0;right:0;height:2px;top:0;background:linear-gradient(90deg,transparent,rgba(99,102,241,.7),transparent);animation:scanV 3s ease-in-out infinite;pointer-events:none}
@keyframes scanV{0%{top:-2px;opacity:0}8%{opacity:1}92%{opacity:.6}100%{top:100%;opacity:0}}
.badge{display:inline-flex;align-items:center;gap:7px;padding:5px 13px;background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.25);border-radius:99px;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(129,140,248,.9);margin-bottom:28px}
.badge-dot{width:6px;height:6px;border-radius:50%;background:#818cf8;animation:bdot 1.3s ease-in-out infinite}
@keyframes bdot{0%,100%{opacity:1}50%{opacity:.2}}
.lock-wrap{width:64px;height:64px;border-radius:18px;background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.22);display:flex;align-items:center;justify-content:center;margin-bottom:24px}
.lock-svg{width:28px;height:28px}
h1{font-size:clamp(20px,4vw,28px);font-weight:800;letter-spacing:-.02em;color:#f1f5f9;margin-bottom:8px}
.sub{font-size:14px;color:rgba(226,232,240,.45);line-height:1.7;margin-bottom:32px}
.scan{border:1px solid rgba(99,102,241,.14);border-radius:14px;padding:4px;background:rgba(99,102,241,.02);margin-bottom:28px}
.scan-row{display:flex;align-items:center;gap:12px;padding:11px 14px;border-radius:10px}
.scan-row+.scan-row{border-top:1px solid rgba(255,255,255,.04)}
.sd{width:8px;height:8px;border-radius:50%;flex-shrink:0;transition:background .4s,box-shadow .4s}
.sd-done{background:#34d399;box-shadow:0 0 6px rgba(52,211,153,.4)}
.sd-run{background:#818cf8;box-shadow:0 0 8px rgba(129,140,248,.5);animation:sdpulse 1s ease-in-out infinite}
.sd-wait{background:rgba(255,255,255,.12)}
@keyframes sdpulse{0%,100%{opacity:1}50%{opacity:.3}}
.scan-lbl{font-size:13px;color:rgba(226,232,240,.65);flex:1}
.scan-val{font-size:12px;transition:color .4s}
.sv-ok{color:#34d399}
.sv-run{color:#818cf8;animation:bdot 1.2s ease-in-out infinite}
.sv-wait{color:rgba(226,232,240,.25)}
.spinner{width:13px;height:13px;border-radius:50%;border:2px solid rgba(129,140,248,.2);border-top-color:#818cf8;animation:spin .8s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.footer{font-size:11.5px;color:rgba(226,232,240,.22);line-height:1.6}
.footer a{color:rgba(99,102,241,.55);font-weight:500;text-decoration:none}
.footer a:hover{color:rgba(129,140,248,.8)}
</style>
</head>
<body>
<div class="card">
  <div class="badge"><span class="badge-dot"></span><span id="badge-txt"></span></div>
  <div class="lock-wrap">
    <svg class="lock-svg" viewBox="0 0 24 24" fill="none">
      <rect x="5" y="11" width="14" height="10" rx="3" fill="rgba(99,102,241,.12)" stroke="#6366f1" stroke-width="1.5"/>
      <path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="12" cy="16" r="1.5" fill="#818cf8"/>
    </svg>
  </div>
  <h1 id="title"></h1>
  <p class="sub" id="subtitle"></p>
  <div class="scan" id="scan-box"></div>
  <div class="footer" id="footer-txt"></div>
</div>
<script>
(function(){
  var verifyURI = "{{ .VerifyURI }}";
  var I={
    en:{badge:"Security Scan",title:"Identity Verification",sub:"Tarinio WAF is verifying your browser. This is a one-time automated check.",steps:["TLS handshake","Browser fingerprint","Threat analysis","Access token","Redirect"],stOk:"Verified",stRun:"Scanning",stWait:"Pending",stDone:"Complete",footer:'Protected by <a href="https://github.com/BerkutSolutions/tarinio" target="_blank" rel="noopener">Tarinio WAF</a> &nbsp;·&nbsp; Do not refresh this page'},
    ru:{badge:"Проверка",title:"Проверка личности",sub:"Tarinio WAF проверяет ваш браузер. Это разовая автоматическая проверка.",steps:["TLS рукопожатие","Отпечаток браузера","Анализ угроз","Токен доступа","Перенаправление"],stOk:"Готово",stRun:"Сканирую",stWait:"Ожидание",stDone:"Завершено",footer:'Защищено <a href="https://github.com/BerkutSolutions/tarinio" target="_blank" rel="noopener">Tarinio WAF</a> &nbsp;·&nbsp; Не обновляйте страницу'},
    de:{badge:"Sicherheitsscan",title:"Identitätsprüfung",sub:"Tarinio WAF überprüft Ihren Browser. Dies ist eine einmalige automatische Prüfung.",steps:["TLS-Handshake","Browser-Fingerabdruck","Bedrohungsanalyse","Zugriffstoken","Weiterleitung"],stOk:"Verifiziert",stRun:"Scannen",stWait:"Ausstehend",stDone:"Abgeschlossen",footer:'Geschützt von <a href="https://github.com/BerkutSolutions/tarinio" target="_blank" rel="noopener">Tarinio WAF</a> &nbsp;·&nbsp; Seite nicht aktualisieren'},
    sr:{badge:"Безбедносни скен",title:"Верификација идентитета",sub:"Tarinio WAF верификује ваш прегледач. Ово јеједнократна аутоматска провера.",steps:["TLS руковање","Отисак прегледача","Анализа претњи","Приступни токен","Преусмеравање"],stOk:"Верификовано",stRun:"Скенирам",stWait:"На чекању",stDone:"Завршено",footer:'Заштићено са <a href="https://github.com/BerkutSolutions/tarinio" target="_blank" rel="noopener">Tarinio WAF</a> &nbsp;·&nbsp; Не освежавајте страницу'},
    zh:{badge:"安全扫描",title:"身份验证",sub:"Tarinio WAF 正在验证您的浏览器。这是一次性的自动检查。",steps:["TLS握手","浏览器指纹","威胁分析","访问令牌","重定向"],stOk:"已验证",stRun:"扫描中",stWait:"等待中",stDone:"完成",footer:'受 <a href="https://github.com/BerkutSolutions/tarinio" target="_blank" rel="noopener">Tarinio WAF</a> 保护 &nbsp;·&nbsp; 请勿刷新页面'}
  };
  var lang=(navigator.language||'en').slice(0,2);
  var l=I[lang]||I.en;
  var isPreview=!location.search.includes('_waf_token')&&location.pathname.includes('preview');

  function readReturnTarget(){
    var params=new URLSearchParams(window.location.search||"");
    var uri=String(params.get("return_uri")||"/").trim();
    var args=String(params.get("return_args")||"").trim();
    if(!uri||uri.charAt(0)!=="/")uri="/";
    return{uri:uri,args:args};
  }
  function buildVerifyURL(t){
    var base=new URL(verifyURI,window.location.origin).toString();
    var q="return_uri="+encodeURI(t.uri||"/");
    if(t.args)q+="&return_args="+encodeURIComponent(t.args);
    return base+(base.indexOf("?")>=0?"&":"?")+q;
  }

  document.getElementById('badge-txt').textContent=l.badge;
  document.getElementById('title').textContent=l.title;
  document.getElementById('subtitle').textContent=l.sub;
  document.getElementById('footer-txt').innerHTML=l.footer;

  var steps=l.steps;
  var box=document.getElementById('scan-box');
  function renderRows(active){
    box.innerHTML=steps.map(function(s,i){
      var isDone=i<active,isRun=i===active;
      return '<div class="scan-row">'+
        '<div class="sd '+(isDone?'sd-done':isRun?'sd-run':'sd-wait')+'"></div>'+
        '<span class="scan-lbl">'+s+'</span>'+
        (isRun?'<span class="scan-val sv-run">'+l.stRun+'</span><div class="spinner"></div>':
         isDone?'<span class="scan-val sv-ok">'+l.stOk+'</span>':
         '<span class="scan-val sv-wait">'+l.stWait+'</span>')+
        '</div>';
    }).join('');
  }

  var timings=[400,900,1700,2400,3000];
  var current=0;
  renderRows(0);
  function advance(){
    current++;
    if(current<steps.length){renderRows(current);setTimeout(advance,timings[current]-timings[current-1]);}
    else{
      renderRows(steps.length);
      if(!isPreview){
        var t=readReturnTarget();
        setTimeout(function(){fetch(buildVerifyURL(t),{credentials:"same-origin"}).then(function(){window.location.replace(t.uri+(t.args?"?"+t.args:""));});},500);
      }
    }
  }
  setTimeout(advance,timings[0]);
})();
</script>
</body>
</html>

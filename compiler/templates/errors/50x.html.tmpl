<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Service Unavailable</title>
  <style>
    :root { color-scheme: dark; }
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 12px;
      background: radial-gradient(circle at top, #142744 0%, #050b18 60%, #030711 100%);
      color: #e8eefc;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      padding: 16px;
    }
    .card {
      width: min(560px, calc(100vw - 40px));
      border: 1px solid #294d7f;
      border-radius: 14px;
      background: linear-gradient(180deg, #12233d, #0a1529);
      box-shadow: 0 16px 40px rgba(0,0,0,.38);
      padding: 22px;
      box-sizing: border-box;
      text-align: center;
    }
    .title { margin: 0; font-size: 24px; line-height: 1.25; }
    .powered {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 20px !important;
      z-index: 20;
      margin: 0;
      padding-bottom: 0;
      color: rgba(180, 203, 239, 0.9);
      font-size: 13px;
      text-align: center;
    }
    .powered a {
      color: #d3e4ff;
      text-decoration: none;
      border-bottom: 1px solid rgba(211, 228, 255, 0.45);
    }
    .powered a:hover {
      border-bottom-color: rgba(211, 228, 255, 0.9);
    }
  </style>
</head>
<body>
  <article class="card">
    <h1 class="title" id="title">Service Unavailable</h1>
  </article>
  <div class="powered">
    <a href="https://github.com/BerkutSolutions/tarinio" target="_blank" rel="noopener noreferrer">Secured by Tarinio</a>
  </div>
  <script>
    (function () {
      var messages = {
        en: "Service Unavailable",
        ru: "Сервис временно недоступен"
      };
      var lang = "en";
      try {
        var candidates = [];
        if (Array.isArray(navigator.languages)) candidates = candidates.concat(navigator.languages);
        if (navigator.language) candidates.push(navigator.language);
        for (var i = 0; i < candidates.length; i += 1) {
          var token = String(candidates[i] || "").toLowerCase().split(/[-_]/)[0];
          if (messages[token]) {
            lang = token;
            break;
          }
        }
      } catch (_error) {}
      document.documentElement.lang = lang;
      document.title = messages[lang] || messages.en;
      document.getElementById("title").textContent = messages[lang] || messages.en;
    })();
  </script>
</body>
</html>

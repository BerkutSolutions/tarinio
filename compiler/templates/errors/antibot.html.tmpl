<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Security Check In Progress</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #08111d;
      --panel: rgba(18, 28, 44, 0.96);
      --line: rgba(122, 164, 255, 0.16);
      --text: #eef4ff;
      --muted: rgba(238, 244, 255, 0.72);
      --accent: #8ab4ff;
      --accent-soft: rgba(138, 180, 255, 0.14);
      --ok: #74d8a4;
      --warn: #ffcd72;
      --bad: #ff8d8d;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", Inter, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, rgba(86, 148, 255, 0.2), transparent 34%),
        radial-gradient(circle at 80% 10%, rgba(84, 211, 162, 0.12), transparent 26%),
        var(--bg);
      display: grid;
      place-items: center;
      padding: 24px;
    }
    .shell {
      width: min(760px, 100%);
      border: 1px solid var(--line);
      border-radius: 20px;
      background: var(--panel);
      box-shadow: 0 28px 64px rgba(0, 0, 0, 0.32);
      overflow: hidden;
    }
    .hero {
      padding: 28px 30px 18px;
      border-bottom: 1px solid var(--line);
    }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 0 0 rgba(138, 180, 255, 0.5);
      animation: pulse 1.7s ease-out infinite;
    }
    h1 {
      margin: 18px 0 0;
      font-size: clamp(30px, 4vw, 44px);
      line-height: 1.05;
    }
    .sub {
      margin: 12px 0 0;
      max-width: 640px;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.6;
    }
    .body {
      padding: 22px 30px 30px;
      display: grid;
      gap: 18px;
    }
    .status {
      display: grid;
      gap: 12px;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 18px;
      background: linear-gradient(180deg, var(--accent-soft), transparent);
    }
    .status strong {
      font-size: 15px;
    }
    .status-line {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.55;
    }
    .spinner {
      width: 18px;
      height: 18px;
      border-radius: 999px;
      border: 2px solid rgba(255, 255, 255, 0.14);
      border-top-color: var(--accent);
      animation: spin 1s linear infinite;
      flex: 0 0 auto;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
    .tile {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
      background: rgba(255, 255, 255, 0.03);
    }
    .tile h2 {
      margin: 0 0 8px;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
    }
    .tile p {
      margin: 0;
      font-size: 14px;
      line-height: 1.55;
      color: var(--text);
    }
    .footer {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }
    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }
    .btn {
      appearance: none;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.05);
      color: var(--text);
      padding: 10px 14px;
      border-radius: 12px;
      font: inherit;
      cursor: pointer;
    }
    .btn[hidden] {
      display: none;
    }
    .hint-ok { color: var(--ok); }
    .hint-warn { color: var(--warn); }
    .hint-bad { color: var(--bad); }
    .powered {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 20px !important;
      z-index: 20;
      margin: 0;
      padding-bottom: 0;
      color: var(--muted);
      font-size: 13px;
      text-align: center;
    }
    .powered a {
      color: #cfe1ff;
      text-decoration: none;
      border-bottom: 1px solid rgba(207, 225, 255, 0.35);
    }
    .powered a:hover {
      border-bottom-color: rgba(207, 225, 255, 0.85);
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(138, 180, 255, 0.5); }
      70% { box-shadow: 0 0 0 12px rgba(138, 180, 255, 0); }
      100% { box-shadow: 0 0 0 0 rgba(138, 180, 255, 0); }
    }
    @media (max-width: 760px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main class="shell">
    <section class="hero">
      <div class="eyebrow"><span class="dot"></span><span id="eyebrow-label">Security Check In Progress</span></div>
      <h1 id="hero-title">Performing browser verification</h1>
      <p class="sub" id="hero-sub">This site is protected by TARINIO anti-bot challenge mode. The check runs automatically, issues a site-scoped verification cookie, and returns you to the page you originally requested.</p>
    </section>
    <section class="body">
      <article class="status">
        <strong id="status-title">Preparing challenge</strong>
        <div class="status-line"><span class="spinner" aria-hidden="true"></span><span id="status-text">Checking browser capabilities and preparing a short redirect through the verification endpoint.</span></div>
      </article>
      <section class="grid">
        <article class="tile">
          <h2 id="tile-browser-title">Browser</h2>
          <p id="browser-state">Waiting for client checks.</p>
        </article>
        <article class="tile">
          <h2 id="tile-cookie-title">Cookie</h2>
          <p id="cookie-state">Cookie not issued yet.</p>
        </article>
        <article class="tile">
          <h2 id="tile-return-title">Return</h2>
          <p id="return-state">The original path will open automatically after verification.</p>
        </article>
      </section>
      <div class="actions">
        <button id="retry-btn" class="btn" type="button" hidden>Retry check</button>
      </div>
      <div class="footer" id="footer-text">If the page does not advance, review your browser privacy extensions and cookie settings, then retry the verification.</div>
    </section>
  </main>
  <div class="powered">
    <a href="https://github.com/BerkutSolutions/tarinio" target="_blank" rel="noopener noreferrer">Secured by Tarinio</a>
  </div>
  <script>
    (function () {
      var verifyURI = "{{ .VerifyURI }}";
      var retryBtn = document.getElementById("retry-btn");
      var statusTitle = document.getElementById("status-title");
      var statusText = document.getElementById("status-text");
      var browserState = document.getElementById("browser-state");
      var cookieState = document.getElementById("cookie-state");
      var returnState = document.getElementById("return-state");
      var messages = {
        en: {
          pageTitle: "Security Check In Progress",
          eyebrow: "Security Check In Progress",
          heroTitle: "Performing browser verification",
          heroSub: "This site is protected by TARINIO anti-bot challenge mode. The check runs automatically, issues a site-scoped verification cookie, and returns you to the page you originally requested.",
          statusPreparingTitle: "Preparing challenge",
          statusPreparingText: "Checking browser capabilities and preparing a short redirect through the verification endpoint.",
          tileBrowser: "Browser",
          tileCookie: "Cookie",
          tileReturn: "Return",
          browserWaiting: "Waiting for client checks.",
          cookieWaiting: "Cookie not issued yet.",
          returnWaiting: "The original path will open automatically after verification.",
          retry: "Retry check",
          footer: "If the page does not advance, review your browser privacy extensions and cookie settings, then retry the verification.",
          failTitle: "Verification did not complete",
          failCookie: "Challenge cookie was not issued.",
          noApi: "Required browser APIs are unavailable.",
          noApiDetail: "The browser does not expose the APIs required for the JavaScript challenge.",
          noCookie: "Cookies are disabled.",
          noCookieDetail: "Cookies are disabled, so the site cannot persist the anti-bot verification result.",
          checksPassed: "Browser checks passed.",
          issueCookieTitle: "Issuing challenge cookie",
          issueCookieText: "The browser check passed. Redirecting through the verification endpoint and back to the requested page.",
          cookieRedirecting: "Challenge cookie will be issued during the redirect."
        },
        ru: {
          pageTitle: "Проверка безопасности",
          eyebrow: "Проверка безопасности",
          heroTitle: "Выполняется проверка браузера",
          heroSub: "Сайт защищён anti-bot режимом TARINIO. Проверка выполняется автоматически, выдаёт cookie верификации для сайта и возвращает вас на исходную страницу.",
          statusPreparingTitle: "Подготовка challenge",
          statusPreparingText: "Проверяем возможности браузера и готовим короткий редирект через endpoint верификации.",
          tileBrowser: "Браузер",
          tileCookie: "Cookie",
          tileReturn: "Возврат",
          browserWaiting: "Ожидание клиентской проверки.",
          cookieWaiting: "Cookie пока не выдана.",
          returnWaiting: "Исходный путь откроется автоматически после верификации.",
          retry: "Повторить проверку",
          footer: "Если страница не продолжает работу, проверьте расширения приватности и настройки cookie, затем повторите проверку.",
          failTitle: "Верификация не завершилась",
          failCookie: "Challenge cookie не была выдана.",
          noApi: "Отсутствуют необходимые API браузера.",
          noApiDetail: "Браузер не предоставляет API, необходимые для JavaScript challenge.",
          noCookie: "Cookie отключены.",
          noCookieDetail: "Cookie отключены, поэтому сайт не может сохранить результат anti-bot верификации.",
          checksPassed: "Проверки браузера пройдены.",
          issueCookieTitle: "Выдача challenge cookie",
          issueCookieText: "Проверка браузера пройдена. Выполняем редирект через endpoint верификации и возвращаем вас на запрошенную страницу.",
          cookieRedirecting: "Challenge cookie будет выдана во время редиректа."
        }
      };
      var lang = "en";
      try {
        var candidates = [];
        if (Array.isArray(navigator.languages)) candidates = candidates.concat(navigator.languages);
        if (navigator.language) candidates.push(navigator.language);
        for (var i = 0; i < candidates.length; i += 1) {
          var token = String(candidates[i] || "").toLowerCase().split(/[-_]/)[0];
          if (messages[token]) {
            lang = token;
            break;
          }
        }
      } catch (_langError) {}
      function m(key) {
        var set = messages[lang] || messages.en;
        if (set && Object.prototype.hasOwnProperty.call(set, key)) {
          return set[key];
        }
        return messages.en[key] || key;
      }
      document.documentElement.lang = lang;
      document.title = m("pageTitle");
      document.getElementById("eyebrow-label").textContent = m("eyebrow");
      document.getElementById("hero-title").textContent = m("heroTitle");
      document.getElementById("hero-sub").textContent = m("heroSub");
      statusTitle.textContent = m("statusPreparingTitle");
      statusText.textContent = m("statusPreparingText");
      document.getElementById("tile-browser-title").textContent = m("tileBrowser");
      document.getElementById("tile-cookie-title").textContent = m("tileCookie");
      document.getElementById("tile-return-title").textContent = m("tileReturn");
      browserState.textContent = m("browserWaiting");
      cookieState.textContent = m("cookieWaiting");
      returnState.textContent = m("returnWaiting");
      retryBtn.textContent = m("retry");
      document.getElementById("footer-text").textContent = m("footer");

      function readReturnTarget() {
        var params = new URLSearchParams(window.location.search || "");
        var returnURI = String(params.get("return_uri") || "/").trim();
        var returnArgs = String(params.get("return_args") || "").trim();
        if (!returnURI || returnURI.charAt(0) !== "/") {
          returnURI = "/";
        }
        return { uri: returnURI, args: returnArgs };
      }

      function buildVerifyURL(target) {
        var base = new URL(verifyURI, window.location.origin).toString();
        var query = "return_uri=" + encodeURI(target.uri || "/");
        if (target.args) {
          query += "&return_args=" + encodeURIComponent(target.args);
        }
        return base + (base.indexOf("?") >= 0 ? "&" : "?") + query;
      }

      function reportFailure(message) {
        statusTitle.textContent = m("failTitle");
        statusText.textContent = message;
        cookieState.textContent = m("failCookie");
        cookieState.className = "hint-bad";
        retryBtn.hidden = false;
      }

      function performChecks() {
        if (!window.fetch || !window.URL || !window.URLSearchParams || !window.crypto) {
          browserState.textContent = m("noApi");
          browserState.className = "hint-bad";
          reportFailure(m("noApiDetail"));
          return;
        }
        if (!navigator.cookieEnabled) {
          browserState.textContent = m("noCookie");
          browserState.className = "hint-bad";
          reportFailure(m("noCookieDetail"));
          return;
        }

        browserState.textContent = m("checksPassed");
        browserState.className = "hint-ok";

        var target = readReturnTarget();
        returnState.textContent = target.uri + (target.args ? "?" + target.args : "");
        returnState.className = "hint-ok";

        statusTitle.textContent = m("issueCookieTitle");
        statusText.textContent = m("issueCookieText");

        window.setTimeout(function () {
          cookieState.textContent = m("cookieRedirecting");
          cookieState.className = "hint-ok";
          window.location.replace(buildVerifyURL(target));
        }, 1200);
      }

      if (retryBtn) {
        retryBtn.addEventListener("click", function () {
          retryBtn.hidden = true;
          cookieState.className = "";
          browserState.className = "";
          returnState.className = "";
          performChecks();
        });
      }

      performChecks();
    })();
  </script>
</body>
</html>

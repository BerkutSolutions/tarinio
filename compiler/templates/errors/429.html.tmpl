<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>429 Rate limiting</title>
  <style>
    :root { color-scheme: dark; --bg: #09111c; --panel: rgba(17, 28, 43, 0.94); --line: rgba(132, 170, 255, 0.2); --text: #eef4ff; --muted: rgba(238, 244, 255, 0.74); --accent-soft: rgba(255, 127, 127, 0.18); }

    .code strong { color: var(--text); font-size: 22px; letter-spacing: 0.5px; }
    .title { font-size: clamp(34px, 5vw, 56px); line-height: 1; margin: 0; }
    .subtitle { margin: 10px 0 0; color: var(--muted); max-width: 760px; font-size: 17px; line-height: 1.55; }
    .meta { margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap; }
    .meta-item { display: inline-flex; align-items: center; gap: 8px; padding: 6px 10px; border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.05); color: var(--muted); font-size: 12px; letter-spacing: 0.02em; }
    .meta-item strong { color: var(--text); font-weight: 600; }
    .body { padding: 24px 30px 30px; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 18px; }
    .card { border: 1px solid var(--line); border-radius: 18px; padding: 18px; background: rgba(8, 14, 24, 0.56); }
    .card h2 { margin: 0 0 14px; font-size: 15px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); }
    .accent { background: linear-gradient(135deg, var(--accent-soft), transparent); border-color: rgba(255, 255, 255, 0.08); }
    .state-grid { display: grid; gap: 12px; }
    .state { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px 15px; border-radius: 14px; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); }
    .state strong { display: block; font-size: 15px; margin-bottom: 4px; }
    .state span { color: var(--muted); font-size: 13px; line-height: 1.45; }
    .pill { display: inline-flex; align-items: center; min-height: 30px; padding: 0 12px; border-radius: 999px; font-size: 13px; font-weight: 700; white-space: nowrap; }
    .ok { color: #d7f8ea; background: rgba(85, 211, 158, 0.16); border: 1px solid rgba(85, 211, 158, 0.3); }
    .bad { color: #ffd4d4; background: rgba(255, 127, 127, 0.16); border: 1px solid rgba(255, 127, 127, 0.28); }
    .list { margin: 0; padding-left: 18px; color: var(--muted); line-height: 1.7; }
    .footer { margin-top: 14px; color: var(--muted); font-size: 13px; }
    .powered { position: fixed; left: 0; right: 0; bottom: 20px; z-index: 20; margin: 0; color: var(--muted); font-size: 13px; text-align: center; }
    .powered a { color: #cfe1ff; text-decoration: none; border-bottom: 1px solid rgba(207, 225, 255, 0.35); }
    .powered a:hover { border-bottom-color: rgba(207, 225, 255, 0.85); }
    @media (max-width: 860px) { .body { grid-template-columns: 1fr; } }
  </style>
</head>

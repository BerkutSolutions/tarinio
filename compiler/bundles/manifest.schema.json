{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.waf/manifest.schema.json",
  "title": "WAF Revision Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "revision_id",
    "revision_version",
    "created_at",
    "bundle_checksum",
    "contents"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "revision_id": {
      "type": "string",
      "minLength": 1
    },
    "revision_version": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "bundle_checksum": {
      "type": "string",
      "minLength": 1
    },
    "contents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "kind",
          "checksum"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "nginx_config",
              "modsecurity_config",
              "crs_config",
              "tls_ref",
              "error_asset"
            ]
          },
          "checksum": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
